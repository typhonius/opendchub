FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    build-essential \
    autoconf \
    automake \
    libcrypt-dev \
    libssl-dev \
    netcat-openbsd \
    openssl \
    procps \
    perl \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /root/.opendchub

# Build opendchub
COPY configure.in Makefile.am acconfig.h /build/opendchub/
COPY AUTHORS ChangeLog COPYING INSTALL NEWS README.md TODO /build/opendchub/
RUN ln -s README.md /build/opendchub/README
COPY src/Makefile.am src/*.c src/*.h /build/opendchub/src/

WORKDIR /build/opendchub

RUN automake --add-missing --copy 2>&1 || true
RUN autoreconf -fi 2>&1 || autoconf -f 2>&1
RUN ./configure --enable-ssl 2>&1 | tail -5
RUN make clean 2>/dev/null; make
RUN ls -la src/opendchub

# Copy test scripts
COPY test/ /build/test/
RUN chmod +x /build/test/run.sh /build/test/dc_client.pl

CMD ["/build/test/run.sh"]
